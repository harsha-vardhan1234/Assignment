<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             version="3.0">

    <persistence-unit name="demo1">

        <!-- Entity class -->
       <!-- <class>Employees</class>-->

        <properties>

            <!-- Oracle JDBC Driver -->
            <property name="jakarta.persistence.jdbc.driver" value="oracle.jdbc.OracleDriver"/>

            <!-- JDBC URL -->
            <!-- Format: jdbc:oracle:thin:@localhost:1521:xe -->
            <property name="jakarta.persistence.jdbc.url" value="jdbc:oracle:thin:@//localhost:5521/FREEPDB1"/>

            <!-- DB Credentials -->
            <property name="jakarta.persistence.jdbc.user" value="EMANDATE"/>
            <property name="jakarta.persistence.jdbc.password" value="root"/>

            <!-- Hibernate Dialect for Oracle -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.OracleDialect"/>

            <!-- Auto table creation -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <!-- Show SQL -->
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>

        </properties>

    </persistence-unit>

</persistence>